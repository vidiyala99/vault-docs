# Copy to .env and fill in. Everything has a working default for local dev
# EXCEPT the OpenAI key — and the system runs without one too (deterministic
# fallback mode: extractive summaries, template answers, local embeddings).

# OpenAI (optional — leave empty to run in deterministic fallback mode)
OPENAI_API_KEY=

# Postgres (matches docker-compose.yml; host port 5433 to avoid clashing
# with any Postgres already running on 5432)
DATABASE_URL=postgresql+psycopg://vault:vault@localhost:5433/vault

# Redis (RQ task queue; host port 6380, same reasoning)
REDIS_URL=redis://localhost:6380/0

# Where uploaded files are stored (local filesystem backend)
STORAGE_DIR=./storage
